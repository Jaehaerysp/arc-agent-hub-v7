# Circle kit key from the Circle Console. Server-only — never prefix this
# with VITE_ or reference it from any file under src/. Real value looks
# like: KIT_KEY:xxxxxxxx:xxxxxxxx
CIRCLE_KIT_KEY=

# Host the Stablecoin/Swap Kit API actually lives at. Confirm this against
# the failing cross-origin request in browser devtools (Network tab) when
# you hit the CORS error client-side, then update if it differs.
CIRCLE_SWAP_API_HOST=https://api.circle.com

# Origin Vite's dev server runs on, so this server's CORS middleware can
# allow that one origin (not '*').
FRONTEND_ORIGIN=http://localhost:5173

PORT=8787
